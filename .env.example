# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Stripe Payment Links (B2B)
VITE_STRIPE_B2B_EMAIL=
VITE_STRIPE_B2B_LINKEDIN=
VITE_STRIPE_B2B_FULLSTACK=

# Stripe Payment Links (VC / DealFlow Scout)
VITE_STRIPE_VC_DEALFLOW=

# Stripe Webhook Secret (set as Supabase Edge Function secret, NOT as a VITE_ var)
STRIPE_WEBHOOK_SECRET=

# Google Calendar (set these as Supabase Edge Function secrets, NOT as VITE_ vars)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# GOOGLE_CALENDAR_ID=

# App
# Gmail (set as Supabase Edge Function secrets, NOT as VITE_ vars)
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=
# GMAIL_SENDER_EMAIL=

# Gmail VC (optional — falls back to SSANZ Gmail if not set)
# GMAIL_VC_CLIENT_ID=
# GMAIL_VC_CLIENT_SECRET=
# GMAIL_VC_REFRESH_TOKEN=
# GMAIL_VC_SENDER_EMAIL=


# App
VITE_APP_URL=https://onboarding.ssanzgrowthai.inc
